{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug VORIS (CMake)",
            "type": "cppdbg",
            "request": "launch",
            // Caminho exato para o binário gerado pelo seu CMake
            "program": "${workspaceFolder}/build/eventcam_stereo",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}